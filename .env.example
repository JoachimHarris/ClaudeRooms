# ClaudeRooms server configuration (all optional — sensible defaults exist)

# Port for the collaboration server (default: 3001)
CLAUDEROOMS_PORT=3001

# SQLite database file (default: apps/server/data/clauderooms.db)
# Use ":memory:" for an ephemeral database.
CLAUDEROOMS_DB=

# Allowed browser origins for WebSocket upgrades, comma-separated
# (default: http://localhost:5173)
CLAUDEROOMS_ALLOWED_ORIGINS=

# Never put real API keys in this file. ClaudeRooms itself needs no API key
# in Milestone 1; from Milestone 3 the *local bridge* uses your existing
# Claude Code login on the host machine.
