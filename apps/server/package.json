{
  "name": "@clauderooms/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/lib.ts"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false --exclude \"**/node_modules/**\" --exclude \"../../node_modules/**\" src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clauderooms/shared": "workspace:*",
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.1",
    "better-sqlite3": "^11.8.0",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4",
    "ws": "^8.18.0"
  }
}
