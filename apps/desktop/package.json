{
  "name": "@clauderooms/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ClaudeRooms host application (Electron shell)",
  "main": "dist/main.mjs",
  "scripts": {
    "dev": "node build.mjs && electron .",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs && tsc --noEmit",
    "package": "node build.mjs && electron-builder --dir",
    "test": "vitest run"
  },
  "devDependencies": {
    "@clauderooms/server": "workspace:*",
    "@clauderooms/shared": "workspace:*",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "electron": "^33.3.1",
    "electron-builder": "^25",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.1",
    "better-sqlite3": "^11.8.0",
    "fastify": "^5.2.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  }
}
